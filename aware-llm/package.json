{
	"name": "aware-llm",
	"version": "0.1.0",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile aware-llm",
		"start": "bun src/index.ts",
		"lint": "biome check --write",
		"format": "biome format --write",
		"format:check": "biome check --formatter-enabled=true --linter-enabled=false",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"db:ensure": "bun ./scripts/ensure-table.ts",
		"db:verify": "bun ./scripts/verify-data.ts",
		"preinstall": "npx only-allow bun",
		"postinstall": "lefthook install"
	},
	"dependencies": {
		"@aws-sdk/client-dynamodb": "^3.975.0",
		"@aws-sdk/lib-dynamodb": "^3.975.0",
		"@hono/standard-validator": "^0.2.2",
		"@openai/agents": "^0.3.9",
		"@scalar/hono-api-reference": "^0.9.33",
		"@t3-oss/env-core": "^0.13.10",
		"dotenv": "^17.2.3",
		"hono": "^4.11.4",
		"hono-openapi": "^1.1.2",
		"winston": "^3.19.0",
		"winston-daily-rotate-file": "^5.0.0",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/bun": "^1.3.6",
		"@types/node": "^25.0.9",
		"lefthook": "^2.0.15",
		"tsdown": "^0.20.0-beta.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
